<section id="gallery" class="section gallery-section">
  <div class="section-header">
    <h2>Photo Gallery</h2>
    <p>Authentic lifestyle imagery and product visuals from the Win Or Lose 350 X 06 Drift Man universe.</p>
  </div>
  <div class="gallery-grid">
    {% for i in (1..3) %}
      <article class="photo-card">
        <div class="photo-image photo-image-{{ i }}">
          <img src="{{ 'IMG_7358.JPG' | asset_url }}" alt="Gallery image {{ i }}" />
        </div>
        <div class="photo-copy"><span>Gallery {{ i }}</span></div>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{ "name": "Gallery", "settings": [], "presets": [{"name":"Gallery"}] }
{% endschema %}
